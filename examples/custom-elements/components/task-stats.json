{
  "$schema": "../../../packages/schema/schema.json",
  "$id": "TaskStats",
  "tagName": "task-stats",

  "state": {
    "tasks": [],

    "total": {
      "$prototype": "Function",
      "body": "return state.tasks.length"
    },

    "done": {
      "$prototype": "Function",
      "body": "return state.tasks.filter(t => t.done).length"
    },

    "remaining": {
      "$prototype": "Function",
      "body": "return state.tasks.filter(t => !t.done).length"
    }
  },

  "style": {
    "display": "flex",
    "justifyContent": "space-between",
    "padding": "0.75em 1em",
    "backgroundColor": "#f8f9fa",
    "borderRadius": "0 0 8px 8px",
    "fontSize": "0.85em",
    "color": "#666"
  },

  "children": [
    {
      "tagName": "span",
      "textContent": "${state.remaining} remaining"
    },
    {
      "tagName": "span",
      "textContent": "${state.done} / ${state.total} completed"
    }
  ]
}
