{
  "tagName": "div",
  "$media": {
    "--": "1280px",
    "--lg": "(max-width: 1024px)",
    "--md": "(max-width: 768px)",
    "--sm": "(max-width: 640px)"
  },
  "style": {
    "display": "block",
    "padding": "4rem 1rem",
    "backgroundColor": "#555"
  },
  "children": [
    {
      "tagName": "div",
      "style": { "maxWidth": "1280px", "margin": "0 auto" },
      "children": [
        {
          "tagName": "h2",
          "style": {
            "textAlign": "center",
            "marginBottom": "3rem",
            "color": "#fff",
            "fontSize": "2.5rem"
          },
          "textContent": "Our Services"
        },
        {
          "tagName": "div",
          "style": {
            "display": "grid",
            "gridTemplateColumns": "1fr 1fr 1fr",
            "gap": "2rem",
            "@--md": { "gridTemplateColumns": "1fr" }
          },
          "children": [
            {
              "tagName": "div",
              "style": { "padding": "1rem", "backgroundColor": "#777" },
              "textContent": "Service 1"
            },
            {
              "tagName": "div",
              "style": { "padding": "1rem", "backgroundColor": "#777" },
              "textContent": "Service 2"
            },
            {
              "tagName": "div",
              "style": { "padding": "1rem", "backgroundColor": "#777" },
              "textContent": "Service 3"
            }
          ]
        }
      ]
    }
  ]
}
