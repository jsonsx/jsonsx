{
  "name": "JX Suite",
  "url": "https://jxsuite.com",
  "defaults": {
    "layout": "./layouts/base.json",
    "lang": "en"
  },
  "imports": {
    "MarkdownFile": "@jxsuite/parser/MarkdownFile.class.json",
    "MarkdownCollection": "@jxsuite/parser/MarkdownCollection.class.json"
  },
  "$head": [
    { "tagName": "link", "attributes": { "rel": "icon", "href": "/favicon.svg" } },
    { "tagName": "meta", "attributes": { "name": "generator", "content": "JX Suite" } },
    {
      "tagName": "meta",
      "attributes": { "name": "viewport", "content": "width=device-width, initial-scale=1" }
    }
  ],
  "$media": {
    "--": "1280px",
    "--lg": "(max-width: 1024px)",
    "--md": "(max-width: 768px)",
    "--sm": "(max-width: 640px)"
  },
  "style": {
    "--color-bg-primary": "#0a0a0a",
    "--color-bg-secondary": "#111111",
    "--color-bg-surface": "#1a1a1a",
    "--color-bg-surface-hover": "#222222",
    "--color-border": "#222222",
    "--color-border-subtle": "#1a1a1a",
    "--color-text-primary": "#fafafa",
    "--color-text-secondary": "#a1a1aa",
    "--color-text-muted": "#71717a",
    "--color-accent": "#3b82f6",
    "--color-accent-hover": "#60a5fa",
    "--font-mono": "'JetBrains Mono', 'SF Mono', Consolas, 'Liberation Mono', Menlo, monospace",
    "--radius": "8px",
    "--radius-lg": "12px",
    "--max-width": "1200px",
    "margin": "0",
    "padding": "0",
    "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "backgroundColor": "var(--color-bg-primary)",
    "color": "var(--color-text-primary)"
  },
  "collections": {
    "docs": {
      "source": "./content/docs/*.md",
      "schema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["title"]
      }
    }
  },
  "copy": {
    "../../packages/schema/schema.json": "schema/v1/index.json",
    "../../packages/schema/project-schema.json": "schema/project/v1/index.json",
    "../../packages/schema/class-schema.json": "schema/class/v1/index.json"
  },
  "build": {
    "outDir": "./dist",
    "format": "directory",
    "trailingSlash": "always"
  }
}
