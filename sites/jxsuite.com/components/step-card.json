{
  "tagName": "step-card",
  "state": {
    "number": "1",
    "title": "",
    "description": ""
  },
  "style": {
    "display": "block",
    "textAlign": "center",
    "padding": "2rem 1.5rem"
  },
  "children": [
    {
      "tagName": "div",
      "style": {
        "width": "3rem",
        "height": "3rem",
        "borderRadius": "50%",
        "border": "2px solid var(--color-border)",
        "display": "flex",
        "alignItems": "center",
        "justifyContent": "center",
        "margin": "0 auto 1.25rem",
        "fontFamily": "var(--font-mono)",
        "fontSize": "0.875rem",
        "fontWeight": "700",
        "color": "var(--color-accent)"
      },
      "textContent": "${state.number}"
    },
    {
      "tagName": "h3",
      "style": {
        "fontSize": "1.0625rem",
        "fontWeight": "600",
        "margin": "0 0 0.5rem"
      },
      "textContent": "${state.title}"
    },
    {
      "tagName": "p",
      "style": {
        "color": "var(--color-text-secondary)",
        "fontSize": "0.875rem",
        "margin": "0",
        "lineHeight": "1.6"
      },
      "textContent": "${state.description}"
    }
  ]
}
