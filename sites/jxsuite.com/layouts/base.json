{
  "tagName": "div",
  "style": {
    "margin": "0",
    "padding": "0",
    "color": "var(--color-text-primary)",
    "lineHeight": "1.6",
    "minHeight": "100vh",
    "display": "flex",
    "flexDirection": "column"
  },
  "$elements": [
    { "$ref": "../components/site-toolbar.json" },
    { "$ref": "../components/site-footer.json" }
  ],
  "children": [
    { "tagName": "site-toolbar" },
    {
      "tagName": "main",
      "style": { "flex": "1" },
      "children": [{ "tagName": "slot" }]
    },
    { "tagName": "site-footer" }
  ]
}
