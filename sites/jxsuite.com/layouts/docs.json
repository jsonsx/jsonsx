{
  "tagName": "div",
  "style": {
    "margin": "0",
    "padding": "0",
    "color": "var(--color-text-primary)",
    "lineHeight": "1.6",
    "minHeight": "100vh",
    "display": "flex",
    "flexDirection": "column"
  },
  "$elements": [
    { "$ref": "../components/site-toolbar.json" },
    { "$ref": "../components/site-footer.json" },
    { "$ref": "../components/docs-sidebar.json" }
  ],
  "children": [
    { "tagName": "site-toolbar" },
    {
      "tagName": "div",
      "style": {
        "flex": "1",
        "display": "flex",
        "maxWidth": "var(--max-width)",
        "margin": "0 auto",
        "width": "100%"
      },
      "children": [
        {
          "tagName": "aside",
          "style": {
            "width": "240px",
            "flexShrink": "0",
            "borderRight": "1px solid var(--color-border)",
            "position": "sticky",
            "top": "3.5rem",
            "height": "calc(100vh - 3.5rem)",
            "overflowY": "auto",
            "paddingRight": "0.5rem",
            "@--md": { "display": "none" }
          },
          "children": [{ "tagName": "docs-sidebar" }]
        },
        {
          "tagName": "main",
          "style": {
            "flex": "1",
            "minWidth": "0",
            "padding": "clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 3vw, 2.5rem)"
          },
          "children": [{ "tagName": "slot" }]
        }
      ]
    },
    { "tagName": "site-footer" }
  ]
}
