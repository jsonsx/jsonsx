{
  "dependencies": {
    "@webref/css": "^8.5.6",
    "@webref/elements": "^2.7.1",
    "@webref/idl": "^3.78.0"
  },
  "description": "JSON Schema 2020-12 meta-schema generator for Jx documents",
  "exports": {
    ".": "./src/schema.js"
  },
  "files": [
    "src/",
    "*.json",
    "!package.json"
  ],
  "license": "MIT",
  "name": "@jxsuite/schema",
  "publishConfig": {
    "provenance": true
  },
  "repository": {
    "directory": "packages/schema",
    "type": "git",
    "url": "git+https://github.com/jxsuite/jx.git"
  },
  "scripts": {
    "schema": "bun run src/schema.js",
    "test": "bun test",
    "upgrade": "bunx npm-check-updates -u && bun install"
  },
  "type": "module",
  "version": "0.5.3"
}
