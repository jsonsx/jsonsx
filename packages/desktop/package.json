{
  "name": "@jxsuite/desktop",
  "version": "0.9.0",
  "description": "Jx Studio — standalone desktop application built with Electrobun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jxsuite/jx.git",
    "directory": "packages/desktop"
  },
  "type": "module",
  "scripts": {
    "build": "bunx electrobun build",
    "build:release": "bunx electrobun build --env=canary",
    "build:stable": "bunx electrobun build --env=stable",
    "chromium": "bun run scripts/pre-build.ts && bun run src/chromium-mode.ts",
    "dev": "bunx electrobun dev",
    "upgrade": "bunx npm-check-updates -u && bun install"
  },
  "dependencies": {
    "@jxsuite/server": "workspace:^",
    "@jxsuite/studio": "workspace:^",
    "electrobun": "latest"
  }
}
